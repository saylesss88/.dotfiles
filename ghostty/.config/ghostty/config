# theme = /usr/share/themes/"Cobalt Neon"
window-theme = ghostty
theme = "TokyoNight"
# theme = "Cobalt Neon"
# command = /usr/bin/nu
command = /usr/bin/zsh
# config-file = ~/.config/randpaper/themes/ghostty.config

##FONTS##
# font-family = "Noto Sans CJK JP"
font-family = "IosevkaCharonMono-Regular"
font-size = 15
font-style-bold = "Medium" 
font-style-bold-italic = "Medium Italic "
font-thicken = true
cursor-invert-fg-bg = true

image-storage-limit = 320000000

##Mouse##
mouse-hide-while-typing = true
# mouse-scroll-multiplier = 1
##Window##
gtk-single-instance = true
gtk-tabs-location = bottom
gtk-wide-tabs = false
window-padding-y = 2,0
window-padding-balance = true
window-decoration = false
background-opacity = 0.8
background-blur = true
background-blur-radius = 10
image-rendering = pixel
unfocused-split-opacity = 1
window-padding-balance = true
adjust-cell-height = 0%

# shell-integration = zsh
shell-integration-features = cursor,sudo,no-title
gtk-titlebar = false

confirm-close-surface = false

##KEYBINDINGS##
keybind = ctrl+l=goto_split:right
keybind = ctrl+h=goto_split:left
keybind = ctrl+k=goto_split:up
keybind = ctrl+j=goto_split:down
keybind = ctrl+shift+|=new_split:right
keybind = ctrl+shift+_=new_split:down
keybind = alt+n=new_window
keybind = alt+t=new_tab
keybind = alt+]=next_tab
keybind = alt+[=previous_tab

#Helix these conflict
keybind = alt+left=unbind
keybind = alt+right=unbind
