{
    "layer": "top",
    "position": "top",
    "height": 33,
    "margin": "10, 5, 0, 5",
    "modules-left": ["custom/launcher","custom/separator","cpu","custom/separator","memory","custom/separator","network","custom/separator","custom/updates","custom/separator","custom/keyboard-layout","custom/separator","custom/network_traffic","custom/separator","idle_inhibitor"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": [ "tray", "custom/separator", "backlight", "custom/separator", "battery", "custom/separator", "pipewire", "custom/separator", "clock", "custom/separator","custom/power"],

    "custom/launcher": {
        "format": " яМК ",
        "tooltip": false,
        "on-click": "rofi -show drun"
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "all-outputs": true,
        "sort-by-number": true,
        "format-icons": {
            "urgent": "яБк",
            "active": "яЖТ",
            "default": "яДС"
        },
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1"
    },

    "custom/separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },

    "tray": {
        "icon-size": 20,
        "spacing": 6
    },

    "clock": {
        "tooltip-format": "<big>{:%A, %d.%B %Y }</big>\n<tt><small>{calendar}</small></tt>",
        "format": "яД│ {:%a %d %b яАЧ %I:%M %p}",
        "format-alt": "яД│ {:%d/%m/%Y яАЧ %H:%M:%S}",
        "interval": 1,
        "on-click": "~/.config/waybar/scripts/OCV"
    },

    "cpu": {
        "format": "яЛЫ {usage}%",
        "on-click": "foot btop"
    },

    "memory": {
        "interval": 30,
        "format": "яГЙ {used:0.1f}GB",
        "on-click": "foot btop",
        "max-length": 10,
        "critical": 80
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["яЖЕ", "яДС"],
        "on-scroll-down": "brightnessctl set 1%-",
        "on-scroll-up": "brightnessctl set +1%",
        "on-click": "~/.config/waybar/scripts/backlight-hint.sh"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "яГз {capacity}%",
        "format-plugged": "яГз {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },

    "network": {
     //"interface": "wlp0s20f3", // (Optional) To force the use of this interface  "format-wifi": "яЗл  {essid}",
        "format": "тЪаDisabled",
        "format-wifi": "яЗл;({signalStrength}%)",
        "format-ethernet": "яЮЦ({signalStrength}%)",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "тЪаDisabled",
        "family": "ipv4",
        "tooltip-format-wifi": "яЗл  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "яЮЦ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "on-click": "nm-connection-editor",
        "tooltip-format": "{essid}: {ipaddr}",
    },

    "custom/updates": {
    "format": "{} {icon}",
    "return-type": "json",
    "format-icons": {
        "has-updates": "ґ▒Н╖",
        "updated": "ґ░Вк"
    },
    "interval": 3600, // Checks once per hour
    "exec": "~/.config/waybar/scripts/updates.sh",
    "on-click": "foot sh -c 'rpm-ostree upgrade && echo \"Upgrade staged! Please reboot to apply.\" && read'"
},

    "custom/power": {
        "format":"тП╗",
        "on-click": "nwgbar",
        "tooltip": false
    },

    "custom/keyboard-layout": {
        "format": "яДЬ Cheat",
        "on-click": "~/.local/bin/keyhint.sh"
    },

    "pipewire": {
        "format": "{icon} {volume}%",
        "format-muted": "яСж",
        "on-click": "pavucontrol",
        "format-icons": {
            "default": ["яАж", "яАз", "яАи"]
        }
    }
}
